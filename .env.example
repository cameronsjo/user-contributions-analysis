# Optional: GitHub token for higher rate limits (5000/hr vs 60/hr) and GraphQL access
# GITHUB_TOKEN=ghp_your_token_here

# Optional: Gitea instance
# GITEA_URL=https://gitea.example.com
# GITEA_TOKEN=your_gitea_token

# Optional: Anthropic API key for narrative summaries
# ANTHROPIC_API_KEY=sk-ant-your_key_here
